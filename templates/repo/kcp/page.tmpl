{{template "base/head" .}}
<div role="main" aria-label="{{.Title}}" class="page-content repository kcp-repo-page">
	{{template "repo/header" .}}
	<div class="ui container">
		{{template "base/alert" .}}

		<div class="tw-mt-4 tw-mb-4">
			<h2 class="ui header">KYBa repository interface</h2>
			<p class="text light">{{.KCPRepo.HelpText}}</p>
		</div>

		<div class="ui secondary pointing menu">
			{{range .KCPRepo.Nav}}
				<a class="item{{if .Active}} active{{end}}" href="{{.Href}}">{{.Title}}</a>
			{{end}}
		</div>

		{{if eq .KCPRepo.SubPage "overview"}}
			<div class="ui three stackable cards">
				<a class="card" href="{{.RepoLink}}/kcp/imports">
					<div class="content"><div class="header">Imported files</div><div class="description">{{len .KCPRepo.ImportedFiles}} materialized files visible in this repository context.</div></div>
				</a>
				<a class="card" href="{{.RepoLink}}/kcp/exports">
					<div class="content"><div class="header">Exported files</div><div class="description">{{len .KCPRepo.ExportFiles}} repository tree entries available for exported capsules.</div></div>
				</a>
				<a class="card" href="{{.RepoLink}}/kcp/impact">
					<div class="content"><div class="header">Impact</div><div class="description">{{len .KCPRepo.Impact}} dependent maintenance records and draft PR plans.</div></div>
				</a>
			</div>

			<h3 class="ui dividing header">Repository-native KCP model</h3>
			<div class="ui list">
				<div class="item"><strong>Imports</strong> are shown as files materialized into this repository, not as links that require broad access to another repository.</div>
				<div class="item"><strong>Exports</strong> are selected from this repository and published as bounded repository interface capsules.</div>
				<div class="item"><strong>Impact</strong> lists dependent repositories, KYBa maintenance tasks and generated draft PR plans.</div>
			</div>
		{{end}}

		{{if eq .KCPRepo.SubPage "imports"}}
			<h3 class="ui dividing header">Imported files visible in this repository</h3>
			<table class="ui celled table">
				<thead><tr><th>Imported file</th><th>Capsule</th><th>Source repo</th><th>Mode</th><th>Description</th></tr></thead>
				<tbody>
				{{range .KCPRepo.ImportedFiles}}
					<tr>
						<td><code>{{.Path}}</code></td>
						<td><code>{{.CapsuleID}}</code></td>
						<td>{{.SourceRepo}}</td>
						<td><span class="ui small label">{{.Mode}}</span></td>
						<td>{{.Description}}</td>
					</tr>
				{{else}}
					<tr>
						<td colspan="5" class="center aligned text light">No materialized imported capsule files were found under <code>.kyba/imported-capsules/</code> in this repository.</td>
					</tr>
				{{end}}
				</tbody>
			</table>
		{{end}}

		{{if eq .KCPRepo.SubPage "exports"}}
			<h3 class="ui dividing header">Choose files exported by this repository</h3>
			<style>
				.kcp-export-tree {
					border: 1px solid var(--color-secondary);
					border-radius: 0.5rem;
					background: var(--color-box-body);
					max-height: 72vh;
					overflow: auto;
					margin-bottom: 1rem;
				}
				.kcp-tree-row {
					display: grid;
					grid-template-columns: minmax(18rem, 1fr) auto minmax(16rem, 32%);
					align-items: center;
					gap: 1rem;
					min-height: 2.5rem;
					padding: 0.35rem 0.75rem;
					border-top: 1px solid var(--color-secondary);
				}
				.kcp-tree-row:first-child {
					border-top: 0;
				}
				.kcp-tree-row[data-kcp-hidden="true"] {
					display: none;
				}
				.kcp-tree-node {
					display: flex;
					align-items: center;
					min-width: 0;
					padding-left: calc(var(--kcp-depth) * 1.25rem);
				}
				.kcp-tree-toggle,
				.kcp-tree-toggle-spacer {
					flex: 0 0 1.4rem;
					width: 1.4rem;
					height: 1.4rem;
					margin-right: 0.25rem;
				}
				.kcp-tree-toggle {
					border: 0;
					border-radius: 0.25rem;
					background: transparent;
					color: var(--color-text-light);
					cursor: pointer;
					line-height: 1;
				}
				.kcp-tree-toggle:hover {
					background: var(--color-hover);
					color: var(--color-text);
				}
				.kcp-tree-label {
					display: flex;
					align-items: center;
					min-width: 0;
					gap: 0.5rem;
					margin: 0;
					cursor: pointer;
				}
				.kcp-tree-checkbox {
					appearance: auto;
					-webkit-appearance: checkbox;
					position: static;
					opacity: 1;
					pointer-events: auto;
					flex: 0 0 auto;
					width: 1rem;
					height: 1rem;
					margin: 0;
					cursor: pointer;
				}
				.kcp-tree-kind {
					flex: 0 0 auto;
					color: var(--color-text-light);
					font-size: 0.85rem;
				}
				.kcp-tree-name {
					overflow: hidden;
					text-overflow: ellipsis;
					white-space: nowrap;
					font-family: var(--fonts-monospace);
				}
				.kcp-tree-meta,
				.kcp-tree-path {
					color: var(--color-text-light);
					font-size: 0.85rem;
					white-space: nowrap;
				}
				.kcp-tree-path {
					overflow: hidden;
					text-overflow: ellipsis;
					font-family: var(--fonts-monospace);
				}
				.kcp-tree-empty {
					padding: 1.5rem;
					text-align: center;
					color: var(--color-text-light);
				}
				.kcp-tree-toolbar {
					display: flex;
					flex-wrap: wrap;
					align-items: center;
					gap: 0.75rem;
					margin-bottom: 0.75rem;
				}
				.kcp-tree-filter {
					min-width: min(28rem, 100%);
					flex: 1 1 22rem;
				}
				.kcp-tree-filter input {
					width: 100%;
				}
				.kcp-tree-summary {
					color: var(--color-text-light);
					font-size: 0.9rem;
				}
				@media (max-width: 767px) {
					.kcp-tree-row {
						grid-template-columns: minmax(0, 1fr);
						gap: 0.25rem;
					}
					.kcp-tree-meta,
					.kcp-tree-path {
						padding-left: calc(var(--kcp-depth) * 1.25rem + 1.65rem);
					}
				}
			</style>
			<form class="ui form" method="post" action="{{.RepoLink}}/kcp/exports" data-kcp-export-form>
				{{$.CsrfTokenHtml}}
				<div class="kcp-tree-toolbar">
					<div class="ui input kcp-tree-filter">
						<input type="search" placeholder="Filter by path, file or folder name" autocomplete="off" data-kcp-filter>
					</div>
					<div class="ui small basic buttons">
						<button class="ui button" type="button" data-kcp-expand-all>Expand all</button>
						<button class="ui button" type="button" data-kcp-collapse-all>Collapse folders</button>
						<button class="ui button" type="button" data-kcp-select-all>Select all files</button>
						<button class="ui button" type="button" data-kcp-clear-selection>Clear selection</button>
					</div>
					<span class="kcp-tree-summary" data-kcp-filter-summary></span>
				</div>
				<div class="kcp-export-tree" role="tree" aria-label="Repository export file tree">
					{{range .KCPRepo.ExportFiles}}
						<div class="kcp-tree-row" role="treeitem" data-kcp-tree-row data-kcp-kind="{{if .IsDir}}dir{{else}}file{{end}}" data-kcp-path="{{.Path}}">
							<div class="kcp-tree-node" style="--kcp-depth: {{.Depth}};">
								{{if .IsDir}}
									<button class="kcp-tree-toggle" type="button" aria-label="Collapse {{.Path}}" aria-expanded="true" data-kcp-toggle data-kcp-path="{{.Path}}">-</button>
								{{else}}
									<span class="kcp-tree-toggle-spacer" aria-hidden="true"></span>
								{{end}}
								<label class="kcp-tree-label">
									<input
										class="kcp-tree-checkbox"
										type="checkbox"
										value="{{.Path}}"
										data-kcp-form-name="{{if .IsDir}}export_dirs{{else}}export_files{{end}}"
										data-kcp-export-checkbox
										data-kcp-kind="{{if .IsDir}}dir{{else}}file{{end}}"
										data-kcp-path="{{.Path}}"
										data-kcp-file-count="{{.FileCount}}"
										data-kcp-partial="{{if .Partial}}true{{else}}false{{end}}"
										{{if .Selected}}checked{{end}}>
									<span class="kcp-tree-kind">{{if .IsDir}}folder{{else}}file{{end}}</span>
									<span class="kcp-tree-name">{{.Name}}</span>
								</label>
							</div>
							<div class="kcp-tree-meta" style="--kcp-depth: {{.Depth}};">
								<span class="ui small label">{{.Mode}}</span>
								{{if .IsDir}}<span>{{.FileCount}} files</span>{{end}}
							</div>
							<code class="kcp-tree-path" style="--kcp-depth: {{.Depth}};">{{.Path}}</code>
						</div>
					{{else}}
						<div class="kcp-tree-empty">
							This repository has no files available for KCP export.
						</div>
					{{end}}
				</div>
				<div class="field">
					<button class="ui primary button" type="submit">Save export selection preview</button>
					<span class="text light" data-kcp-selection-count>{{.KCPRepo.SelectedCount}} files selected for export preview.</span>
				</div>
			</form>
		{{end}}

		{{if eq .KCPRepo.SubPage "impact"}}
			<h3 class="ui dividing header">Impact and dependent maintenance</h3>
			<table class="ui celled table">
				<thead><tr><th>Capsule</th><th>Dependent repository</th><th>Status</th><th>KYBa task</th><th>Draft PR plan</th></tr></thead>
				<tbody>
				{{range .KCPRepo.Impact}}
					<tr><td><code>{{.CapsuleID}}</code></td><td>{{.Repository}}</td><td><span class="ui small label">{{.Status}}</span></td><td>{{.Task}}</td><td>{{.DraftPR}}</td></tr>
				{{else}}
					<tr>
						<td colspan="5" class="center aligned text light">No repository-scoped KCP impact records were found for the current imports or export preview.</td>
					</tr>
				{{end}}
				</tbody>
			</table>
		{{end}}
	</div>
</div>
{{if eq .KCPRepo.SubPage "exports"}}
<script type="module">
	const form = document.querySelector('[data-kcp-export-form]');
	if (form) {
		const filter = form.querySelector('[data-kcp-filter]');
		const filterSummary = form.querySelector('[data-kcp-filter-summary]');
		const count = form.querySelector('[data-kcp-selection-count]');
		const parentPath = (path) => {
			const index = path.lastIndexOf('/');
			return index > 0 ? path.slice(0, index) : '';
		};
		const under = (path, dir) => path !== dir && path.startsWith(`${dir}/`);

		const records = Array.from(form.querySelectorAll('[data-kcp-tree-row]')).map((row) => {
			const box = row.querySelector('[data-kcp-export-checkbox]');
			return {
				row,
				box,
				toggle: row.querySelector('[data-kcp-toggle]'),
				path: row.dataset.kcpPath,
				pathLower: row.dataset.kcpPath.toLowerCase(),
				kind: row.dataset.kcpKind,
				fileCount: Number(box?.dataset.kcpFileCount || 0),
			};
		});
		const fileRecords = records.filter((record) => record.kind === 'file');
		const dirRecords = records.filter((record) => record.kind === 'dir');
		const topLevelDirs = dirRecords.filter((record) => !record.path.includes('/'));
		const rootFiles = fileRecords.filter((record) => !record.path.includes('/'));
		const selectedDirs = new Set(dirRecords.filter((record) => record.box.checked).map((record) => record.path));
		const selectedFiles = new Set();
		const collapsed = new Set(topLevelDirs.map((record) => record.path));

		const nearestSelectedDir = (path) => {
			for (let parent = parentPath(path); parent; parent = parentPath(parent)) {
				if (selectedDirs.has(parent)) return parent;
			}
			return '';
		};
		for (const record of fileRecords) {
			if (record.box.checked && !nearestSelectedDir(record.path)) {
				selectedFiles.add(record.path);
			}
		}

		const appendHiddenInput = (name, value) => {
			const input = document.createElement('input');
			input.type = 'hidden';
			input.name = name;
			input.value = value;
			input.className = 'kcp-selection-hidden';
			form.append(input);
		};
		const removeDescendantSelections = (path) => {
			for (const dir of Array.from(selectedDirs)) {
				if (under(dir, path)) selectedDirs.delete(dir);
			}
			for (const file of Array.from(selectedFiles)) {
				if (under(file, path)) selectedFiles.delete(file);
			}
		};
		const materializeSelectedAncestorExcept = (selectedAncestor, excludedPath) => {
			selectedDirs.delete(selectedAncestor);
			for (const file of Array.from(selectedFiles)) {
				if (file === excludedPath || under(file, excludedPath)) {
					selectedFiles.delete(file);
				}
			}
			for (const file of fileRecords) {
				if (!under(file.path, selectedAncestor)) continue;
				if (file.path === excludedPath || under(file.path, excludedPath)) continue;
				selectedFiles.add(file.path);
			}
		};
		const isFileSelected = (path) => selectedFiles.has(path) || Boolean(nearestSelectedDir(path));
		const isHiddenByCollapsedParent = (path) => {
			for (let parent = parentPath(path); parent; parent = parentPath(parent)) {
				if (collapsed.has(parent)) return true;
			}
			return false;
		};
		const matchingAncestorPaths = (path, visiblePaths) => {
			for (let parent = parentPath(path); parent; parent = parentPath(parent)) {
				visiblePaths.add(parent);
			}
		};
		const updateTreeVisibility = () => {
			const query = filter?.value.trim().toLowerCase() || '';
			const visiblePaths = new Set();
			let matches = 0;
			if (query) {
				for (const record of records) {
					if (!record.pathLower.includes(query)) continue;
					visiblePaths.add(record.path);
					matchingAncestorPaths(record.path, visiblePaths);
					matches++;
				}
			}
			for (const record of records) {
				const visible = query ? visiblePaths.has(record.path) : !isHiddenByCollapsedParent(record.path);
				record.row.dataset.kcpHidden = visible ? 'false' : 'true';
			}
			for (const record of dirRecords) {
				if (!record.toggle) continue;
				const path = record.path;
				const isCollapsed = collapsed.has(path);
				record.toggle.textContent = isCollapsed ? '+' : '-';
				record.toggle.setAttribute('aria-expanded', String(!isCollapsed));
				record.toggle.setAttribute('aria-label', `${isCollapsed ? 'Expand' : 'Collapse'} ${path}`);
			}
			if (filterSummary) {
				if (query) {
					filterSummary.textContent = `${matches} ${matches === 1 ? 'match' : 'matches'}`;
				} else {
					filterSummary.textContent = `${fileRecords.length} files, ${dirRecords.length} folders`;
				}
			}
		};
		const updateSelectionState = () => {
			let selectedCount = 0;
			const selectedCountByDir = new Map();
			for (const record of fileRecords) {
				const selected = isFileSelected(record.path);
				record.box.checked = selected;
				record.box.indeterminate = false;
				if (!selected) continue;
				selectedCount++;
				for (let parent = parentPath(record.path); parent; parent = parentPath(parent)) {
					selectedCountByDir.set(parent, (selectedCountByDir.get(parent) || 0) + 1);
				}
			}
			for (const record of dirRecords) {
				const selected = selectedCountByDir.get(record.path) || 0;
				record.box.checked = record.fileCount > 0 && selected === record.fileCount;
				record.box.indeterminate = selected > 0 && selected < record.fileCount;
			}
			if (count) {
				count.textContent = `${selectedCount} ${selectedCount === 1 ? 'file' : 'files'} selected for export preview.`;
			}
		};
		for (const record of dirRecords) {
			record.toggle?.addEventListener('click', () => {
				const path = record.path;
				if (collapsed.has(path)) {
					collapsed.delete(path);
				} else {
					collapsed.add(path);
				}
				updateTreeVisibility();
			});
		}
		for (const record of records) {
			record.box.addEventListener('change', () => {
				const path = record.path;
				const selectedAncestor = nearestSelectedDir(path);
				if (record.kind === 'dir') {
					if (record.box.checked) {
						if (selectedAncestor) {
							record.box.checked = true;
						} else {
							selectedDirs.add(path);
							removeDescendantSelections(path);
						}
					} else if (selectedDirs.has(path)) {
						selectedDirs.delete(path);
						removeDescendantSelections(path);
					} else if (selectedAncestor) {
						materializeSelectedAncestorExcept(selectedAncestor, path);
					}
				} else if (record.box.checked) {
					selectedFiles.add(path);
				} else if (selectedAncestor) {
					materializeSelectedAncestorExcept(selectedAncestor, path);
				} else {
					selectedFiles.delete(path);
				}
				updateSelectionState();
			});
		}
		form.querySelector('[data-kcp-select-all]')?.addEventListener('click', () => {
			selectedDirs.clear();
			selectedFiles.clear();
			for (const record of topLevelDirs) {
				selectedDirs.add(record.path);
			}
			for (const record of rootFiles) {
				selectedFiles.add(record.path);
			}
			updateSelectionState();
		});
		form.querySelector('[data-kcp-clear-selection]')?.addEventListener('click', () => {
			selectedDirs.clear();
			selectedFiles.clear();
			updateSelectionState();
		});
		form.querySelector('[data-kcp-expand-all]')?.addEventListener('click', () => {
			collapsed.clear();
			updateTreeVisibility();
		});
		form.querySelector('[data-kcp-collapse-all]')?.addEventListener('click', () => {
			collapsed.clear();
			for (const record of topLevelDirs) {
				collapsed.add(record.path);
			}
			updateTreeVisibility();
		});
		filter?.addEventListener('input', updateTreeVisibility);
		form.addEventListener('submit', () => {
			for (const input of form.querySelectorAll('.kcp-selection-hidden')) {
				input.remove();
			}
			for (const dir of Array.from(selectedDirs).sort()) {
				appendHiddenInput('export_dirs', dir);
			}
			for (const file of Array.from(selectedFiles).sort()) {
				appendHiddenInput('export_files', file);
			}
		});
		updateSelectionState();
		updateTreeVisibility();
	}
</script>
{{end}}
{{template "base/footer" .}}
