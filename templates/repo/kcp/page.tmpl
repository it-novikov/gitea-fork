{{template "base/head" .}}
<div role="main" aria-label="{{.Title}}" class="page-content repository kcp-repo-page">
	{{template "repo/header" .}}
	<div class="ui container">
		{{template "base/alert" .}}

		<div class="tw-mt-4 tw-mb-4">
			<h2 class="ui header">KYBa repository interface</h2>
			<p class="text light">{{.KCPRepo.HelpText}}</p>
		</div>

		<div class="ui secondary pointing menu">
			{{range .KCPRepo.Nav}}
				<a class="item{{if .Active}} active{{end}}" href="{{.Href}}">{{.Title}}</a>
			{{end}}
		</div>

		{{if eq .KCPRepo.SubPage "overview"}}
			<div class="ui three stackable cards">
				<a class="card" href="{{.RepoLink}}/kcp/imports">
					<div class="content"><div class="header">Imported files</div><div class="description">{{len .KCPRepo.ImportedFiles}} materialized files visible in this repository context.</div></div>
				</a>
				<a class="card" href="{{.RepoLink}}/kcp/exports">
					<div class="content"><div class="header">Exported files</div><div class="description">{{len .KCPRepo.ExportFiles}} repository tree entries available for exported capsules.</div></div>
				</a>
				<a class="card" href="{{.RepoLink}}/kcp/impact">
					<div class="content"><div class="header">Impact</div><div class="description">{{len .KCPRepo.Impact}} dependent maintenance records and draft PR plans.</div></div>
				</a>
			</div>

			<h3 class="ui dividing header">Repository-native KCP model</h3>
			<div class="ui list">
				<div class="item"><strong>Imports</strong> are shown as files materialized into this repository, not as links that require broad access to another repository.</div>
				<div class="item"><strong>Exports</strong> are selected from this repository and published as bounded repository interface capsules.</div>
				<div class="item"><strong>Impact</strong> lists dependent repositories, KYBa maintenance tasks and generated draft PR plans.</div>
			</div>
		{{end}}

		{{if eq .KCPRepo.SubPage "imports"}}
			<h3 class="ui dividing header">Imported files visible in this repository</h3>
			<table class="ui celled table">
				<thead><tr><th>Imported file</th><th>Capsule</th><th>Source repo</th><th>Mode</th><th>Description</th></tr></thead>
				<tbody>
				{{range .KCPRepo.ImportedFiles}}
					<tr>
						<td><code>{{.Path}}</code></td>
						<td><code>{{.CapsuleID}}</code></td>
						<td>{{.SourceRepo}}</td>
						<td><span class="ui small label">{{.Mode}}</span></td>
						<td>{{.Description}}</td>
					</tr>
				{{else}}
					<tr>
						<td colspan="5" class="center aligned text light">No materialized imported capsule files were found under <code>.kyba/imported-capsules/</code> in this repository.</td>
					</tr>
				{{end}}
				</tbody>
			</table>
		{{end}}

		{{if eq .KCPRepo.SubPage "exports"}}
			<h3 class="ui dividing header">Choose files exported by this repository</h3>
			<style>
				.kcp-export-tree {
					border: 1px solid var(--color-secondary);
					border-radius: 0.5rem;
					background: var(--color-box-body);
					overflow: hidden;
					margin-bottom: 1rem;
				}
				.kcp-tree-row {
					display: grid;
					grid-template-columns: minmax(18rem, 1fr) auto minmax(16rem, 32%);
					align-items: center;
					gap: 1rem;
					min-height: 2.5rem;
					padding: 0.35rem 0.75rem;
					border-top: 1px solid var(--color-secondary);
				}
				.kcp-tree-row:first-child {
					border-top: 0;
				}
				.kcp-tree-row[data-kcp-hidden="true"] {
					display: none;
				}
				.kcp-tree-node {
					display: flex;
					align-items: center;
					min-width: 0;
					padding-left: calc(var(--kcp-depth) * 1.25rem);
				}
				.kcp-tree-toggle,
				.kcp-tree-toggle-spacer {
					flex: 0 0 1.4rem;
					width: 1.4rem;
					height: 1.4rem;
					margin-right: 0.25rem;
				}
				.kcp-tree-toggle {
					border: 0;
					border-radius: 0.25rem;
					background: transparent;
					color: var(--color-text-light);
					cursor: pointer;
					line-height: 1;
				}
				.kcp-tree-toggle:hover {
					background: var(--color-hover);
					color: var(--color-text);
				}
				.kcp-tree-label {
					display: flex;
					align-items: center;
					min-width: 0;
					gap: 0.5rem;
					margin: 0;
					cursor: pointer;
				}
				.kcp-tree-checkbox {
					appearance: auto;
					-webkit-appearance: checkbox;
					position: static;
					opacity: 1;
					pointer-events: auto;
					flex: 0 0 auto;
					width: 1rem;
					height: 1rem;
					margin: 0;
					cursor: pointer;
				}
				.kcp-tree-kind {
					flex: 0 0 auto;
					color: var(--color-text-light);
					font-size: 0.85rem;
				}
				.kcp-tree-name {
					overflow: hidden;
					text-overflow: ellipsis;
					white-space: nowrap;
					font-family: var(--fonts-monospace);
				}
				.kcp-tree-meta,
				.kcp-tree-path {
					color: var(--color-text-light);
					font-size: 0.85rem;
					white-space: nowrap;
				}
				.kcp-tree-path {
					overflow: hidden;
					text-overflow: ellipsis;
					font-family: var(--fonts-monospace);
				}
				.kcp-tree-empty {
					padding: 1.5rem;
					text-align: center;
					color: var(--color-text-light);
				}
				@media (max-width: 767px) {
					.kcp-tree-row {
						grid-template-columns: minmax(0, 1fr);
						gap: 0.25rem;
					}
					.kcp-tree-meta,
					.kcp-tree-path {
						padding-left: calc(var(--kcp-depth) * 1.25rem + 1.65rem);
					}
				}
			</style>
			<form class="ui form" method="post" action="{{.RepoLink}}/kcp/exports" data-kcp-export-form>
				{{$.CsrfTokenHtml}}
				<div class="ui small basic buttons tw-mb-3">
					<button class="ui button" type="button" data-kcp-select-all> Select all files</button>
					<button class="ui button" type="button" data-kcp-clear-selection>Clear selection</button>
				</div>
				<div class="kcp-export-tree" role="tree" aria-label="Repository export file tree">
					{{range .KCPRepo.ExportFiles}}
						<div class="kcp-tree-row" role="treeitem" data-kcp-tree-row data-kcp-kind="{{if .IsDir}}dir{{else}}file{{end}}" data-kcp-path="{{.Path}}">
							<div class="kcp-tree-node" style="--kcp-depth: {{.Depth}};">
								{{if .IsDir}}
									<button class="kcp-tree-toggle" type="button" aria-label="Collapse {{.Path}}" aria-expanded="true" data-kcp-toggle data-kcp-path="{{.Path}}">-</button>
								{{else}}
									<span class="kcp-tree-toggle-spacer" aria-hidden="true"></span>
								{{end}}
								<label class="kcp-tree-label">
									<input
										class="kcp-tree-checkbox"
										type="checkbox"
										name="{{if .IsDir}}export_dirs{{else}}export_files{{end}}"
										value="{{.Path}}"
										data-kcp-export-checkbox
										data-kcp-kind="{{if .IsDir}}dir{{else}}file{{end}}"
										data-kcp-path="{{.Path}}"
										data-kcp-partial="{{if .Partial}}true{{else}}false{{end}}"
										{{if .Selected}}checked{{end}}>
									<span class="kcp-tree-kind">{{if .IsDir}}folder{{else}}file{{end}}</span>
									<span class="kcp-tree-name">{{.Name}}</span>
								</label>
							</div>
							<div class="kcp-tree-meta" style="--kcp-depth: {{.Depth}};">
								<span class="ui small label">{{.Mode}}</span>
								{{if .IsDir}}<span>{{.FileCount}} files</span>{{end}}
							</div>
							<code class="kcp-tree-path" style="--kcp-depth: {{.Depth}};">{{.Path}}</code>
						</div>
					{{else}}
						<div class="kcp-tree-empty">
							This repository has no files available for KCP export.
						</div>
					{{end}}
				</div>
				<div class="field">
					<button class="ui primary button" type="submit">Save export selection preview</button>
					<span class="text light" data-kcp-selection-count>{{.KCPRepo.SelectedCount}} files selected for export preview.</span>
				</div>
			</form>
		{{end}}

		{{if eq .KCPRepo.SubPage "impact"}}
			<h3 class="ui dividing header">Impact and dependent maintenance</h3>
			<table class="ui celled table">
				<thead><tr><th>Capsule</th><th>Dependent repository</th><th>Status</th><th>KYBa task</th><th>Draft PR plan</th></tr></thead>
				<tbody>
				{{range .KCPRepo.Impact}}
					<tr><td><code>{{.CapsuleID}}</code></td><td>{{.Repository}}</td><td><span class="ui small label">{{.Status}}</span></td><td>{{.Task}}</td><td>{{.DraftPR}}</td></tr>
				{{else}}
					<tr>
						<td colspan="5" class="center aligned text light">No repository-scoped KCP impact records were found for the current imports or export preview.</td>
					</tr>
				{{end}}
				</tbody>
			</table>
		{{end}}
	</div>
</div>
{{if eq .KCPRepo.SubPage "exports"}}
<script type="module">
	const form = document.querySelector('[data-kcp-export-form]');
	if (form) {
		const boxes = Array.from(form.querySelectorAll('[data-kcp-export-checkbox]'));
		const rows = Array.from(form.querySelectorAll('[data-kcp-tree-row]'));
		const toggles = Array.from(form.querySelectorAll('[data-kcp-toggle]'));
		const count = form.querySelector('[data-kcp-selection-count]');
		const collapsed = new Set();
		const files = () => boxes.filter((box) => box.dataset.kcpKind === 'file');
		const dirs = () => boxes.filter((box) => box.dataset.kcpKind === 'dir');
		const parentPath = (path) => {
			const index = path.lastIndexOf('/');
			return index > 0 ? path.slice(0, index) : '';
		};
		const under = (path, dir) => path !== dir && path.startsWith(`${dir}/`);
		const descendantFiles = (dir) => files().filter((box) => under(box.dataset.kcpPath, dir));
		const isHiddenByCollapsedParent = (path) => {
			for (let parent = parentPath(path); parent; parent = parentPath(parent)) {
				if (collapsed.has(parent)) return true;
			}
			return false;
		};
		const updateTreeVisibility = () => {
			for (const row of rows) {
				row.dataset.kcpHidden = isHiddenByCollapsedParent(row.dataset.kcpPath) ? 'true' : 'false';
			}
			for (const toggle of toggles) {
				const path = toggle.dataset.kcpPath;
				const isCollapsed = collapsed.has(path);
				toggle.textContent = isCollapsed ? '+' : '-';
				toggle.setAttribute('aria-expanded', String(!isCollapsed));
				toggle.setAttribute('aria-label', `${isCollapsed ? 'Expand' : 'Collapse'} ${path}`);
			}
		};
		const updateFolders = () => {
			for (const box of dirs()) {
				const children = descendantFiles(box.dataset.kcpPath);
				const selected = children.filter((child) => child.checked).length;
				box.checked = children.length > 0 && selected === children.length;
				box.indeterminate = selected > 0 && selected < children.length;
			}
		};
		const updateCount = () => {
			if (!count) return;
			const selected = files().filter((box) => box.checked).length;
			count.textContent = `${selected} ${selected === 1 ? 'file' : 'files'} selected for export preview.`;
		};
		const update = () => {
			updateFolders();
			updateCount();
		};
		for (const toggle of toggles) {
			toggle.addEventListener('click', () => {
				const path = toggle.dataset.kcpPath;
				if (collapsed.has(path)) {
					collapsed.delete(path);
				} else {
					collapsed.add(path);
				}
				updateTreeVisibility();
			});
		}
		for (const box of boxes) {
			box.indeterminate = box.dataset.kcpPartial === 'true';
			box.addEventListener('change', () => {
				if (box.dataset.kcpKind === 'dir') {
					for (const child of boxes) {
						if (under(child.dataset.kcpPath, box.dataset.kcpPath)) {
							child.checked = box.checked;
							child.indeterminate = false;
						}
					}
				}
				update();
			});
		}
		form.querySelector('[data-kcp-select-all]')?.addEventListener('click', () => {
			for (const box of boxes) {
				box.checked = true;
				box.indeterminate = false;
			}
			update();
		});
		form.querySelector('[data-kcp-clear-selection]')?.addEventListener('click', () => {
			for (const box of boxes) {
				box.checked = false;
				box.indeterminate = false;
			}
			update();
		});
		update();
		updateTreeVisibility();
	}
</script>
{{end}}
{{template "base/footer" .}}
